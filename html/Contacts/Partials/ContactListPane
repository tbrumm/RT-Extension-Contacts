<%ARGS>
$filter  => 'all'
$group_id => 0
$q       => ''
$page    => 0
</%ARGS>
<%INIT>
use RT::Extension::Contacts;
use Digest::MD5 qw(md5_hex);

my $current_user = $session{CurrentUser};
unless ( $current_user && $current_user->id ) {
    $r->status(403);
    $m->abort();
}
unless ( $current_user->HasRight( Right => 'SeeContacts', Object => RT->System ) ) {
    $r->status(403);
    $m->abort();
}

my @contacts;
my $total_count = 0;
my $PER_PAGE = 50;

if ( $filter eq 'personal' ) {
    my $rows = RT::Extension::Contacts->GetPersonalContacts( $current_user->id );
    for my $row (@$rows) {
        my $u = RT::User->new( RT->SystemUser );
        $u->Load( $row->{user_id} );
        next unless $u->Id;
        push @contacts, { user => $u, notes => $row->{notes}, marking => 'personal' };
    }
} elsif ( $filter eq 'group' && $group_id ) {
    my $rows = RT::Extension::Contacts->GetGroupContacts( $group_id, $current_user->id );
    for my $row (@$rows) {
        my $u = RT::User->new( RT->SystemUser );
        $u->Load( $row->{user_id} );
        next unless $u->Id;
        push @contacts, { user => $u, notes => $row->{notes}, marking => 'group' };
    }
} elsif ( $filter eq 'search' && length $q ) {
    my $users = RT::Extension::Contacts->SearchUsers( $q, $PER_PAGE );
    while ( my $u = $users->Next ) {
        push @contacts, { user => $u, notes => '', marking => '' };
    }
} else {
    # all
    my $users = RT::Extension::Contacts->GetAllContacts( $PER_PAGE, $page * $PER_PAGE );
    while ( my $u = $users->Next ) {
        push @contacts, { user => $u, notes => '', marking => '' };
    }
    my $cu = RT::Users->new( RT->SystemUser );
    $cu->LimitToEnabled();
    $total_count = $cu->Count;
}
</%INIT>
<div id="contacts-list-content">
% unless (@contacts) {
<div class="text-center text-muted p-4">
  <i class="bi bi-inbox" style="font-size:2rem; opacity:.4;"></i>
  <p class="mt-2 small"><% loc('No contacts found') %></p>
</div>
% }
% for my $c (@contacts) {
%   my $u = $c->{user};
%   my $is_personal = RT::Extension::Contacts->IsPersonalContact( $u->Id, $current_user->id );
%   my $has_rt_image  = $u->ImageContentType ? 1 : 0;
%   my $email_hash    = md5_hex(lc($u->EmailAddress // ''));
%   my $gravatar_url  = "https://www.gravatar.com/avatar/${email_hash}?s=72&d=404";
%   my $display_name  = $u->RealName || $u->Name || '';
%   my @nw = split /\s+/, $display_name;
%   my $initials = '';
%   $initials .= uc(substr($nw[0],  0, 1)) if @nw >= 1;
%   $initials .= uc(substr($nw[-1], 0, 1)) if @nw >= 2;
%   $initials ||= '?';
%   my $hue = 0; $hue = ($hue * 31 + ord($_)) % 360 for split //, $display_name;
%   my $avatar_color = "hsl($hue,55%,45%)";
%   my $avatar_src   = $has_rt_image
%       ? RT->Config->Get('WebPath') . '/Helpers/UserImage/' . $u->Id . '-' . $u->ImageSignature
%       : $gravatar_url;
%   my $avatar_step  = $has_rt_image ? 'rt' : 'gravatar';
<div class="contact-card d-flex align-items-center px-2 py-2 border-bottom contacts-list-item"
     style="cursor:pointer;"
     hx-get="<% RT->Config->Get('WebPath') %>/Contacts/Partials/ContactDetailPane?user_id=<% $u->Id %>"
     hx-target="#contacts-detail-pane"
     hx-select="#contacts-detail-content"
     hx-swap="innerHTML"
     hx-push-url="false">
  <div class="contact-avatar me-2 flex-shrink-0">
    <img src="<% $avatar_src %>"
         data-gravatar="<% $gravatar_url %>"
         data-initials="<% $initials %>"
         data-color="<% $avatar_color %>"
         data-step="<% $avatar_step %>"
         data-size="36"
         onerror="contactAvatarFallback(this)"
         class="rounded-circle"
         style="width:36px;height:36px;object-fit:cover;"
         alt="<% $initials %>">
  </div>
  <div class="contact-info flex-grow-1 overflow-hidden">
    <div class="fw-semibold text-truncate" style="font-size:.9rem;">
      <% $u->RealName || $u->Name %>
    </div>
    <div class="text-muted text-truncate" style="font-size:.8rem;">
      <% $u->EmailAddress %>
    </div>
  </div>
  <div class="contact-badges ms-1 d-flex flex-column gap-1">
%   if ($is_personal) {
    <span class="badge" style="background:var(--bs-success); font-size:.65rem;" title="<% loc('Personal contact') %>">
      <i class="bi bi-heart-fill"></i>
    </span>
%   }
%   if ($c->{marking} eq 'group') {
    <span class="badge" style="background:var(--bs-info); font-size:.65rem;" title="<% loc('Group contact') %>">
      <i class="bi bi-people-fill"></i>
    </span>
%   }
  </div>
</div>
% }
% if ($filter eq 'all' && $total_count > $PER_PAGE) {
%   my $last_page = int(($total_count - 1) / $PER_PAGE);
%   my %show;
%   for my $p (0, 1, $last_page - 1, $last_page, ($page - 2) .. ($page + 2)) {
%     $show{$p} = 1 if $p >= 0 && $p <= $last_page;
%   }
%   my @pages = sort { $a <=> $b } keys %show;
<div class="d-flex flex-wrap gap-1 p-2 justify-content-center border-top">
%   my $prev = -2;
%   for my $p (@pages) {
%     if ($p > $prev + 1) {
  <span class="btn btn-sm disabled px-1" style="pointer-events:none;">...</span>
%     }
  <button class="btn btn-sm <% $p == $page ? 'btn-primary' : 'btn-outline-secondary' %>"
          style="min-width:2.2rem;"
          hx-get="<% RT->Config->Get('WebPath') %>/Contacts/Partials/ContactListPane?filter=all&page=<% $p %>"
          hx-target="#contacts-list-pane"
          hx-select="#contacts-list-content"
          hx-swap="innerHTML">
    <% $p + 1 %>
  </button>
%     $prev = $p;
%   }
</div>
% }
</div><!-- /contacts-list-content -->
